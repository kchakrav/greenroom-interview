# Copy this file to .env.local and fill in all values.

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to claude-opus-4-8).
# For faster/cheaper turns you can use claude-sonnet-4-6.
# AIINTERVIEW_MODEL=claude-opus-4-8

# ── Google OAuth (NextAuth) ───────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
#    (and your production URL when deploying)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base URL of this app (required by NextAuth)
NEXTAUTH_URL=http://localhost:3000

# Random secret for signing JWTs — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
